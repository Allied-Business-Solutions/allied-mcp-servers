# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub - it contains your secret API key

# Your Hudu instance URL (no trailing slash)
HUDU_BASE_URL=https://allied.huducloud.com/api/v1

# Your Hudu API key
# Get this from: Hudu Admin → Basic Information → API Keys
HUDU_API_KEY=your_api_key_here

# Port the MCP server listens on (default: 3000)
PORT=3000
